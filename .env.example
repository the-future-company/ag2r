# AG2R Configuration

# Server
PORT=3000

# CDP (Chrome DevTools Protocol)
CDP_HOST=127.0.0.1
CDP_PORT=9000

# Authentication
# AUTH_ENABLED=false means no login required. The ag2r() shell function
# overrides with AUTH_ENABLED=true for production/tunnel access.
AUTH_ENABLED=false
APP_PASSWORD=antigravity
SESSION_SECRET=change-me-to-a-random-string

# Polling
POLL_INTERVAL_MS=500

# Tunnel (Cloudflare Tunnel)
TUNNEL_ENABLED=false
TUNNEL_URL=https://remote.yourdomain.com

# Hub (dev-only, for multi-worktree development — see hub.js)
# HUB_PORT=3100
# HUB_SCAN_MIN=3000
# HUB_SCAN_MAX=3099
# AG2R_MAIN_DIR=~/Workspace/ag2r
# AG2R_MAIN_PORT=3000

# Telemetry (anonymous usage metrics → Firebase Firestore)
# Set AG2R_TELEMETRY=false to disable. No personal data is collected.
AG2R_TELEMETRY=true
TELEMETRY_FIREBASE_PROJECT_ID=
TELEMETRY_FIREBASE_API_KEY=
