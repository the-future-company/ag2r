# AG2R Configuration

# Server
PORT=3000

# CDP (Chrome DevTools Protocol)
CDP_HOST=127.0.0.1
CDP_PORT=9000

# Authentication
# AUTH_ENABLED=false means no login required. The ag2r() shell function
# overrides with AUTH_ENABLED=true for production/tunnel access.
AUTH_ENABLED=false
APP_PASSWORD=antigravity
SESSION_SECRET=change-me-to-a-random-string

# Polling
POLL_INTERVAL_MS=500

# Tunnel (Cloudflare Tunnel)
TUNNEL_ENABLED=false
TUNNEL_URL=https://remote.yourdomain.com
